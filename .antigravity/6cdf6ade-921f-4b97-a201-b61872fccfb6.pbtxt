el>\n          <input \n            type=\"date\"\n            value={format(date, \'yyyy-MM-dd\')}\n            onChange={(e) => {\n              if (e.target.value) {\n                const newDate = new Date(e.target.value);\n                newDate.setHours(date.getHours(), date.getMinutes());\n                onDateChange(newDate);\n              }\n            }}\n            className=\"w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-200 outline-none focus:ring-2 focus:ring-amber-500/50 color-scheme-dark style-color-scheme-dark\"\n            style={{ colorScheme: \'dark\' }}\n          />\n        </div>\n\n        <button \n          onClick={onToggleFindSun}\n          className={`w-full py-2.5 rounded-lg text-sm font-medium flex items-center justify-center gap-2 transition-all ${\n            findSunActive \n              ? \'bg-amber-500 text-slate-900 shadow-lg shadow-amber-500/20\' \n              : \'bg-slate-800 text-slate-300 hover:bg-slate-700 border border-slate-700\'\n          }`}\n        >"
