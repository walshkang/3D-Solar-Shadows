      replacement_content: "import React, { useState, useEffect, useMemo, useRef } from \'react\';\nimport Map from \'react-map-gl/maplibre\';\nimport \'maplibre-gl/dist/maplibre-gl.css\';\nimport DeckGL from \'@deck.gl/react\';\nimport { GeoJsonLayer, PolygonLayer } from \'@deck.gl/layers\';\nimport { LightingEffect, AmbientLight, SunLight } from \'@deck.gl/core\';\nimport type { MapViewState } from \'@deck.gl/core\';\nimport { fetchOSMBuildings, BuildingCollection } from \'../lib/overpass\';\n\ninterface MapContainerProps {\n  date: Date;\n  findSunActive: boolean;\n  viewState: MapViewState;\n  onViewStateChange: (viewState: MapViewState) => void;\n}\n\nconst MAP_STYLE = \'https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json\';\n\n// Fetch radius helper bounds\nfunction getBoundsFromCenter(lat: number, lng: number, radiusDegrees = 0.015): [number, number, number, number] {\n  return [\n    lng - radiusDegrees, // w\n    lat - radiusDegrees, // s\n    lng + radiusDegrees, // e\n    lat + radiusDegrees  // n\n  ];\n}\n\nexport default function MapContainer({\n  date,\n  findSunActive,\n  viewState,\n  onViewStateChange\n}: MapContainerProps) {\n  \n  const [buildings, setBuildings] = useState<BuildingCollection | null>(null);\n  const [isFetching, setIsFetching] = useState(false);\n  const debounceRef = useRef<NodeJS.Timeout>(null);\n\n  const fetchBuildingsFn = async (lat: number, lng: number) => {\n    setIsFetching(true);\n    const bounds = getBoundsFromCenter(lat, lng);\n    const data = await fetchOSMBuildings(bounds);\n    setBuildings(data);\n    setIsFetching(false);\n  };\n\n  // Debounce viewport coordinate fetching\n  useEffect(() => {\n    if (debounceRef.current) clearTimeout(debounceRef.current);\n    debounceRef.current = setTimeout(() => {\n      fetchBuildingsFn(viewState.latitude, viewState.longitude);\n    }, 1000); // 1s debounce after map stops moving\n    \n    return () => {\n      if (debounceRef.current) clearTimeout(debounceRef.current);\n    };\n  }, [viewState.latitude, viewState.longitude]);\n\n  // Initial load\n  useEffect(() => {\n    fetchBuildingsFn(viewState.latitude, viewState.longitude);\n  }, []);\n\n  // Configure Deck.gl Lighting inside useMemo to ensure stability\n  const effects = useMemo(() => {\n    const ambientLight = new AmbientLight({\n      color: [255, 255, 255],\n      intensity: 0.3\n    });\n    \n    const dirLight = new SunLight({\n      timestamp: date.getTime(),\n      color: [255, 255, 240], // Warm sunlight\n      intensity: 2.0,\n      _shadow: true\n    });\n\n    const lightingEffect = new LightingEffect({ ambientLight, dirLight });\n    lightingEffect.shadowColor = [0, 0, 0, 0.7]; // Darker shadows\n    \n    return [lightingEffect];\n  }, [date]);\n\n  const layers = [\n    // Base floor for shadow catching (large polygon covering the viewport area)\n    new PolygonLayer({\n      id: \'ground-layer\',\n      data: [{\n        polygon: [\n          [viewState.longitude - 0.1, viewState.latitude - 0.1],\n          [viewState.longitude + 0.1, viewState.latitude - 0.1],\n          [viewState.longitude + 0.1, viewState.latitude + 0.1],\n          [viewState.longitude - 0.1, viewState.latitude + 0.1],\n        ]\n      }],\n      getPolygon: (d: any) => d.polygon,\n      getFillColor: findSunActive ? [255, 210, 100, 200] : [0, 0, 0, 0], // If find sun is active, make ground yellow\n      stroked: false,\n      extruded: false,\n      material: {\n        ambient: 0.2,\n        diffuse: 0.8,\n        shininess: 32,\n        specularColor: [255, 255, 255]\n      }\n    }),\n\n    // 3D Buildings Layer\n    buildings && new GeoJsonLayer({\n      id: \'3d-buildings\',\n      data: buildings,\n      extruded: true,\n      wireframe: false,\n      pickable: true,\n      getElevation: (f: any) => f.properties.height,\n      getFillColor: [100, 110, 120, 255], // Neutral dark gray for buildings\n      getLineColor: [0, 0, 0, 0],\n      material: {\n        ambient: 0.3,\n        diffuse: 0.7,\n        shininess: 32,\n        specularColor: [80, 80, 80]\n      },\n      transitions: {\n        getElevation: 500\n      }\n    })\n  ].filter(Boolean);\n\n  return (\n    <div className=\"relative w-full h-full bg-slate-900 overflow-hidden\">\n      <DeckGL\n        layers={layers}\n        effects={effects}\n        initialViewState={viewState}\n        onViewStateChange={({ viewState }) => onViewStateChange(viewState as MapViewState)}\n        controller={true}\n        getCursor={() => \'crosshair\'}\n        parameters={{\n          depthTest: true,\n          clearColor: [0, 0, 0, 1] // Ensure clean clearing\n        }}\n      >\n        <Map \n          reuseMaps \n          mapStyle={MAP_STYLE} \n          attributionControl={false}\n        />\n      </DeckGL>\n\n      {isFetching && (\n        <div className=\"absolute top-4 right-4 z-10 bg-black/60 backdrop-blur px-3 py-1.5 rounded text-xs font-mono text-white/70 animate-pulse border border-white/10\">\n          Fetching 3D topology...\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
