    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { Search, MapPin, Calendar as CalendarIcon, Sun } from \'lucide-react\';\nimport { format } from \'date-fns\';\n\ninterface SearchOverlayProps {\n  onLocationSelect: (lat: number, lon: number) => void;\n  date: Date;\n  onDateChange: (date: Date) => void;\n  findSunActive: boolean;\n  onToggleFindSun: () => void;\n}\n\nexport default function SearchOverlay({\n  onLocationSelect,\n  date,\n  onDateChange,\n  findSunActive,\n  onToggleFindSun\n}: SearchOverlayProps) {\n  const [query, setQuery] = useState(\'\');\n  const [results, setResults] = useState<any[]>([]);\n  const [isSearching, setIsSearching] = useState(false);\n\n  const searchLocation = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!query) return;\n    \n    setIsSearching(true);\n    try {\n      const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=5`);\n      const data = await res.json();\n      setResults(data);\n    } catch (error) {\n      console.error(error);\n    } finally {\n      setIsSearching(false);\n    }\n  };\n\n  return (\n    <div className=\"absolute top-4 left-4 z-10 flex flex-col gap-4 w-80\">\n      \n      {/* Search Box */}\n      <div className=\"bg-white/90 backdrop-blur-md rounded-xl shadow-lg border border-white/20 overflow-hidden\">\n        <form onSubmit={searchLocation} className=\"flex flex-row items-center p-2\">\n          <input \n            type=\"text\"\n            value={query}\n            onChange={(e) => setQuery(e.target.value)}\n            placeholder=\"Search city, neighborhood...\"\n            className=\"flex-1 bg-transparent px-3 py-2 text-sm text-gray-800 outline-none placeholder:text-gray-400\"\n          />\n          <button type=\"submit\" className=\"p-2 text-gray-500 hover:text-orange-500 transition-colors\">\n            <Search size={18} />\n          </button>\n        </form>\n\n        {results.length > 0 && (\n          <div className=\"border-t border-gray-100 max-h-48 overflow-y-auto\">\n            {results.map((r, idx) => (\n              <button \n                key={idx}\n                className=\"w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-orange-50 transition-colors flex items-start gap-2\"\n                onClick={() => {\n                  onLocationSelect(parseFloat(r.lat), parseFloat(r.lon));\n                  setResults([]);\n                  setQuery(r.display_name.split(\',\')[0]);\n                }}\n              >\n                <MapPin size={16} className=\"mt-0.5 text-gray-400 shrink-0\" />\n                <span className=\"truncate\">{r.display_name}</span>\n              </button>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {/* Date Picker & Tools */}\n      <div className=\"bg-white/90 backdrop-blur-md rounded-xl shadow-lg border border-white/20 p-4 space-y-4\">\n        \n        <div className=\"space-y-1\">\n          <label className=\"text-xs font-semibold tracking-wider text-gray-500 uppercase flex items-center gap-1.5\">\n            <CalendarIcon size={14} /> Date Selection\n          </label>\n          <input \n            type=\"date\"\n            value={format(date, \'yyyy-MM-dd\')}\n            onChange={(e) => {\n              if (e.target.value) {\n                const newDate = new Date(e.target.value);\n                newDate.setHours(date.getHours(), date.getMinutes());\n                onDateChange(newDate);\n              }\n            }}\n            className=\"w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 outline-none focus:ring-2 focus:ring-orange-500/50\"\n          />\n        </div>\n\n        <button \n          onClick={onToggleFindSun}\n          className={`w-full py-2.5 rounded-lg text-sm font-medium flex items-center justify-center gap-2 transition-all ${\n            findSunActive \n              ? \'bg-amber-500 text-white shadow-md shadow-amber-500/20\' \n              : \'bg-gray-50 text-gray-600 hover:bg-gray-100 border border-gray-200\'\n          }`}\n        >\n          <Sun size={16} className={findSunActive ? \'animate-spin-slow\' : \'\'} />\n          {findSunActive ? \'Highlighting Unshaded Areas\' : \'Find Sun (Floor Highlight)\'}\n        </button>\n\n      </div>\n    </div>\n  );\n}\n"
    }
